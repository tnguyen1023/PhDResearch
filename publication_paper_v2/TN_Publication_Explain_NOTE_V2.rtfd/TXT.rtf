\f13 \uc0\u7496 
\f20 \uc0\u8304 
\f15  \'d7 (1 \uc0\u8722  \u961 \u960 (t) / \u961 
\f5 \cf17 \uc0\u8344 \u8336 
\f13 \cf17 \uc0\u739 
\f15 )\
